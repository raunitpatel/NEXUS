# Enforce LF line endings for all text files
* text=auto eol=lf

# Force LF on all script and config files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.env text eol=lf
*.env.* text eol=lf
Dockerfile text eol=lf
*.conf text eol=lf
*.ps1 text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary