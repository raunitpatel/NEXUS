# =============================================================================
# NEXUS — Memory Agent service environment variables
# Mirrors the fields declared in services/memory_agent/config.py BaseSettings
# ⚠ WINDOWS: Must use LF line endings — see repo root README.md
# =============================================================================

# PostgreSQL + pgvector (services/memory_agent/pgvector_store.py)
DATABASE_URL=postgresql+asyncpg://nexus_user:changeme_postgres_password@postgres:5432/nexus

# Embedding model (services/memory_agent/embeddings.py — no Claude, local only)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# pgvector similarity search parameters
VECTOR_SIMILARITY_THRESHOLD=0.75
VECTOR_TOP_K=10

# Memory Agent server
MEMORY_AGENT_HOST=0.0.0.0
MEMORY_AGENT_PORT=8004
MEMORY_AGENT_LOG_LEVEL=info

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=nexus-memory-agent
NEXUS_ENV=development
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc