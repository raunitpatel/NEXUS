ENVIRONMENT=development
LOG_LEVEL=info
SERVICE_NAME=memory-agent

MEMORY_AGENT_HOST=0.0.0.0
MEMORY_AGENT_PORT=8003

# PostgreSQL + pgvector
DATABASE_URL=postgresql+asyncpg://nexus:nexus_secret@postgres:5432/nexus_db

# Embedding model
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Pgvector similarity search
VECTOR_SIMILARITY_THRESHOLD=0.75
VECTOR_TOP_K=10

# Redis
REDIS_URL=redis://:changeme_redis_password@redis:6379/0
VECTOR_CACHE_TTL_SECONDS=300

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TASKS=nexus.tasks
KAFKA_TOPIC_EVENTS=nexus.events
KAFKA_CONSUMER_GROUP_MEMORY=nexus-memory-agent

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317