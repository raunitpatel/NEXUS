# =============================================================================
# NEXUS — Tool Agent service environment variables
# Mirrors the fields declared in services/tool_agent/config.py BaseSettings
# ⚠ WINDOWS: Must use LF line endings — see repo root README.md
# =============================================================================

# Anthropic (function calling dispatch via services/tool_agent/claude_client.py)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Redis (CachedClaudeClient response cache)
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# Tool Agent server
TOOL_AGENT_HOST=0.0.0.0
TOOL_AGENT_PORT=8005
TOOL_AGENT_LOG_LEVEL=info

# Weather tool — open-meteo.com requires no API key
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1

# Wikipedia tool
WIKIPEDIA_API_BASE_URL=https://en.wikipedia.org/api/rest_v1

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=nexus-tool-agent
NEXUS_ENV=development
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc