ENVIRONMENT=development
LOG_LEVEL=info
SERVICE_NAME=code-agent

TOOL_AGENT_HOST=0.0.0.0
TOOL_AGENT_PORT=8003


DATABASE_URL=postgresql+asyncpg://nexus:changeme_postgres_password@postgres:5432/nexus_db
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

# LLM Provider: "claude" | "gemini" | "ollama"
LLM_PROVIDER=claude

ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TIMEOUT_SECONDS=60

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:7b
OLLAMA_TIMEOUT_SECONDS=120

REDIS_URL=redis://:changeme_redis_password@redis:6379/0

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_EVENTS=nexus.events

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Tool API base URLs
WEATHER_API_BASE_URL="https://api.open-meteo.com/v1"
WIKIPEDIA_API_BASE_URL="https://en.wikipedia.org/api/rest_v1"