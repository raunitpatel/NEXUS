# Application
ENVIRONMENT=development
LOG_LEVEL=info
SERVICE_NAME=orchestrator

# PostgreSQL (service: postgres, internal port: 5432)
DATABASE_URL=postgresql+asyncpg://nexus:changeme_postgres_password@postgres:5432/nexus_db
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TASKS=nexus.tasks
KAFKA_TOPIC_RESULTS=nexus.results
KAFKA_TOPIC_EVENTS=nexus.events
KAFKA_CONSUMER_GROUP_ORCHESTRATOR=nexus-orchestrator

# LLM Provider selection
# possible values: gemini, ollama, claude
LLM_PROVIDER=gemini

# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120

# Anthropic
ANTHROPIC_API_KEY=sk-ant-placeholder
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDs=120

# Gemini
GEMINI_API_KEY=gemini_key_holder
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# Internal agent service URLs (used by dispatch_next_task.py — AGNT-009)
SEARCH_AGENT_URL=http://search-agent:8002
CODE_AGENT_URL=http://code-agent:8003
MEMORY_AGENT_URL=http://memory-agent:8004
TOOL_AGENT_URL=http://tool-agent:8005

# LangGraph execution
MAX_PLAN_RETRIES=3
TASK_TIMEOUT_SECONDS=30
MAX_PARALLEL_TASKS=4

# Circuit breaker (Redis-backed — services/orchestrator/circuit_breaker.py)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60

# OpenTelemetry + Jaeger (shared/telemetry.py)
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317