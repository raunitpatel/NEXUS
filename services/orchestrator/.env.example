# =============================================================================
# NEXUS — Orchestrator service environment variables
# Mirrors the fields declared in services/orchestrator/config.py BaseSettings
# ⚠ WINDOWS: Must use LF line endings — see repo root README.md
# =============================================================================

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://nexus_user:changeme_postgres_password@postgres:5432/nexus

# Redis (SSE pub/sub via orchestrator/sse_emitter.py + circuit breaker)
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TASKS=nexus.tasks
KAFKA_TOPIC_RESULTS=nexus.results
KAFKA_TOPIC_EVENTS=nexus.events
KAFKA_CONSUMER_GROUP_ORCHESTRATOR=nexus-orchestrator

# Anthropic (decompose_query node + synthesize_output node)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Orchestrator server
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8001
ORCHESTRATOR_LOG_LEVEL=info

# LangGraph execution
MAX_PLAN_RETRIES=3
TASK_TIMEOUT_SECONDS=30
MAX_PARALLEL_TASKS=4

# Circuit breaker (orchestrator/circuit_breaker.py)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60

# Internal agent URLs (dispatched via dispatch_next_task.py)
SEARCH_AGENT_URL=http://search-agent:8002
CODE_AGENT_URL=http://code-agent:8003
MEMORY_AGENT_URL=http://memory-agent:8004
TOOL_AGENT_URL=http://tool-agent:8005

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=nexus-orchestrator
NEXUS_ENV=development
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc