# =============================================================================
# NEXUS — Search Agent service environment variables
# Mirrors the fields declared in services/search_agent/config.py BaseSettings
# ⚠ WINDOWS: Must use LF line endings — see repo root README.md
# =============================================================================

# Anthropic (search query formulation + result re-ranking)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Redis (CachedClaudeClient response cache via shared/claude_client.py)
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# External search API (services/search_agent/tools/web_search.py)
SEARCH_API_KEY=your_search_api_key_here
SEARCH_API_BASE_URL=https://api.search-provider.io/v1

# Search Agent server
SEARCH_AGENT_HOST=0.0.0.0
SEARCH_AGENT_PORT=8002
SEARCH_AGENT_LOG_LEVEL=info

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=nexus-search-agent
NEXUS_ENV=development
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc