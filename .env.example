# =============================================================================
# NEXUS — Distributed AI Agent Orchestration Platform
# Root .env.example — canonical reference for ALL services
# Copy to .env and fill in real values before running docker compose
#
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (service: postgres, port: 5432)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nexus
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=changeme_postgres_password

# Full async DSN used by SQLAlchemy 2.0 async engine and asyncpg
DATABASE_URL=postgresql+asyncpg://nexus_user:changeme_postgres_password@postgres:5432/nexus

# -----------------------------------------------------------------------------
# Redis (service: redis, port: 6379)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# -----------------------------------------------------------------------------
# Apache Kafka (service: kafka, port: 9092)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Topic names — must match infra/kafka/create_topics.sh
KAFKA_TOPIC_TASKS=nexus.tasks
KAFKA_TOPIC_RESULTS=nexus.results
KAFKA_TOPIC_EVENTS=nexus.events

# Consumer group IDs
KAFKA_CONSUMER_GROUP_ORCHESTRATOR=nexus-orchestrator
KAFKA_CONSUMER_GROUP_GATEWAY=nexus-gateway

# -----------------------------------------------------------------------------
# Anthropic API (used by: gateway, orchestrator, search_agent, code_agent, tool_agent)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Model is pinned in shared/claude_client.py — do not override here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514  # read-only reference

# -----------------------------------------------------------------------------
# JWT Authentication (service: gateway)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=changeme_jwt_secret_min_32_chars_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# API Gateway (service: gateway, port: 8000)
# -----------------------------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_LOG_LEVEL=info

# Internal service URLs (used by gateway → service HTTP calls via shared/http_client.py)
ORCHESTRATOR_URL=http://orchestrator:8001
SEARCH_AGENT_URL=http://search-agent:8002
CODE_AGENT_URL=http://code-agent:8003
MEMORY_AGENT_URL=http://memory-agent:8004
TOOL_AGENT_URL=http://tool-agent:8005

# Redis rate limiting (token bucket)
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# -----------------------------------------------------------------------------
# Orchestrator (service: orchestrator, port: 8001)
# -----------------------------------------------------------------------------
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8001
ORCHESTRATOR_LOG_LEVEL=info

# LangGraph execution settings
MAX_PLAN_RETRIES=3
TASK_TIMEOUT_SECONDS=30
MAX_PARALLEL_TASKS=4

# Circuit breaker (Redis-backed, see orchestrator/circuit_breaker.py)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------------------
# Search Agent (service: search-agent, port: 8002)
# -----------------------------------------------------------------------------
SEARCH_AGENT_HOST=0.0.0.0
SEARCH_AGENT_PORT=8002
SEARCH_AGENT_LOG_LEVEL=info

# External search API (used by services/search_agent/tools/web_search.py)
SEARCH_API_KEY=your_search_api_key_here
SEARCH_API_BASE_URL=https://api.search-provider.io/v1

# -----------------------------------------------------------------------------
# Code Agent (service: code-agent, port: 8003)
# -----------------------------------------------------------------------------
CODE_AGENT_HOST=0.0.0.0
CODE_AGENT_PORT=8003
CODE_AGENT_LOG_LEVEL=info

# Sandbox execution limits (services/code_agent/executor.py)
CODE_EXECUTION_TIMEOUT_SECONDS=15
CODE_EXECUTION_MAX_OUTPUT_BYTES=65536

# -----------------------------------------------------------------------------
# Memory Agent (service: memory-agent, port: 8004)
# -----------------------------------------------------------------------------
MEMORY_AGENT_HOST=0.0.0.0
MEMORY_AGENT_PORT=8004
MEMORY_AGENT_LOG_LEVEL=info

# sentence-transformers model (services/memory_agent/embeddings.py)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# pgvector similarity search
VECTOR_SIMILARITY_THRESHOLD=0.75
VECTOR_TOP_K=10

# -----------------------------------------------------------------------------
# Tool Agent (service: tool-agent, port: 8005)
# -----------------------------------------------------------------------------
TOOL_AGENT_HOST=0.0.0.0
TOOL_AGENT_PORT=8005
TOOL_AGENT_LOG_LEVEL=info

# Weather tool (services/tool_agent/tools/weather.py — uses open-meteo.com, no key required)
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1

# Wikipedia tool (services/tool_agent/tools/wikipedia.py)
WIKIPEDIA_API_BASE_URL=https://en.wikipedia.org/api/rest_v1

# -----------------------------------------------------------------------------
# OpenTelemetry + Jaeger (shared/telemetry.py — used by all services)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=nexus
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none

# -----------------------------------------------------------------------------
# Prometheus (shared/metrics.py — scraped by infra/prometheus/prometheus.yml)
# -----------------------------------------------------------------------------
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# -----------------------------------------------------------------------------
# Environment tag (used by structlog shared/logging.py for log correlation)
# -----------------------------------------------------------------------------
NEXUS_ENV=development