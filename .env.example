# NEVER commit .env with real secrets.
# All variables here are consumed by docker-compose.yml
# and overridden per-service in services/*/env.example

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=nexus_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis
REDIS_HOST=redis
REDIS_PORT=6379

# ── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TASKS=nexus.tasks
KAFKA_TOPIC_RESULTS=nexus.results
KAFKA_TOPIC_EVENTS=nexus.events

# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-change_me

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Service URLs (internal Docker network) ──────────────────────────────────
GATEWAY_URL=http://gateway:8000
ORCHESTRATOR_URL=http://orchestrator:8001
SEARCH_AGENT_URL=http://search-agent:8002
CODE_AGENT_URL=http://code-agent:8003
MEMORY_AGENT_URL=http://memory-agent:8004
TOOL_AGENT_URL=http://tool-agent:8005

# ── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_JAEGER_ENDPOINT=http://jaeger:14268/api/traces
OTEL_SERVICE_NAME=nexus
PROMETHEUS_PORT=9090